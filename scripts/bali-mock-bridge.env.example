# Darwin-side .env for Brian's mock 1Click bridge stack.
#
# Source of truth for our local dev — copy to .env before running
# `docker compose -f compose.sepolia.yaml up -d`. Lives in this
# repo (not /tmp) so the /tmp cleanup that nuked the previous copy
# can't take it down again.
#
# Verified against compose.sepolia.yaml requirements:
#   - EVM_RPC_URL
#   - MIDEN_RPC_URL
#   - MIDEN_MASTER_SEED_HEX (32-byte hex; bridge derives the solver
#     wallet from this — keep stable across restarts to preserve
#     accounts in the bridge's miden-client local store)
#   - MASTER_MNEMONIC (BIP39 mnemonic for the EVM-side anvil/sepolia
#     keypair the bridge signs with)
#   - DATABASE_URL (mapped to the postgres service inside compose)
#   - BRIDGE_PROFILE=sepolia

BRIDGE_PROFILE=sepolia
BRIDGE_DEMO_ENABLED=1
BRIDGE_UI_ENABLED=1
BRIDGE_CORS_ALLOW_ORIGIN=*

# Sepolia public RPC — same one the darwin-frontend + worker use.
EVM_RPC_URL=https://ethereum-sepolia.publicnode.com

# Miden testnet RPC — same RPC the relay v2 + worker use.
MIDEN_RPC_URL=https://rpc.testnet.miden.io
MIDEN_REMOTE_PROVER_URL=
MIDEN_REMOTE_PROVER_TIMEOUT_SECS=180

# Master seed for the bridge's miden-client. Regenerate ONCE then
# pin — re-running with a different seed invalidates the solver
# account, so every prior deposit becomes unclaimable on its side.
#
# CHANGE THIS for production; the value below is a deterministic
# dev seed acceptable to share in this repo (no real value on
# testnet).
MIDEN_MASTER_SEED_HEX=0101010101010101010101010101010101010101010101010101010101010101

# BIP39 mnemonic the bridge's EVM signer uses. Anvil's default
# (`test test … junk`) works against the Sepolia profile only
# because there's no native ETH gating — it's signing read-mostly
# txs against the bridge contract from a no-balance EOA. For a
# real bridge cycle we'd swap to a funded mnemonic.
MASTER_MNEMONIC=test test test test test test test test test test test junk

# Postgres in-compose. Port-mapped to 55432 outside the network so
# it doesn't collide with a host-side postgres on 5432.
DATABASE_URL=postgres://postgres:postgres@postgres:5432/miden_bridge

# Re-pointing helpers — uncomment to override defaults.
# RUST_LOG=info,miden_testnet_bridge=debug
