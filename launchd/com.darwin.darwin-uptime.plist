<?xml version="1.0" encoding="UTF-8"?>
<!--
  Hits the public-surface checklist every 5 minutes. Silent on
  success; any non-2xx appends a line to /tmp/darwin-uptime.log so
  the operator can scan recent failures (`tail /tmp/darwin-uptime.log`)
  and correlate with the worker/tunnel logs.

  Three probes:
    * GET  /              — Vercel static
    * GET  /api/prices    — Vercel serverless
    * POST /api/position  — Vercel → CF tunnel → Mac → miden-client

  If the position probe fails the most useful follow-up is
  `tail /tmp/darwin-frontend-next.log` and
  `tail /tmp/cf-named-tunnel-frontend.log`.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.darwin.darwin-uptime</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/eden/data/darwin/repos/darwin-infra/scripts/darwin-uptime-ping.sh</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/darwin-uptime-plist.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/darwin-uptime-plist.log</string>
</dict>
</plist>
